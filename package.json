{
  "name": "typescript-demo",
  "version": "0.1.0",
  "description": "A zero-to-hero TypeScript tutorial from hello world to a frontend that talks to an API.",
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit && vitest run",
    "dev:api": "tsx examples/api/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "lesson:01": "tsx lessons/01-hello-world/main.ts",
    "lesson:02": "tsx lessons/02-types-and-values/main.ts",
    "lesson:03": "tsx lessons/03-functions-and-objects/main.ts",
    "lesson:04": "tsx lessons/04-unions-and-narrowing/main.ts",
    "lesson:05": "tsx lessons/05-generics-and-utilities/main.ts",
    "lesson:06": "tsx lessons/06-async-and-errors/main.ts",
    "lesson:07": "tsx lessons/07-modules-and-domain-modeling/main.ts",
    "lesson:api": "tsx examples/api/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
